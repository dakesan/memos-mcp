# memos-mcp environment variables — copy to .env (gitignored) and fill in.
# Do NOT commit real values; .env is ignored on purpose.

# ── Core (used in both stdio and --http modes) ───────────────────────────────
# URL of your Memos instance.
MEMOS_BASE_URL=https://memos.example.com
# Bearer token (Personal Access Token) for the Memos API.
MEMOS_ACCESS_TOKEN=
# Optional. Appended to memo/comment content on creation (after two newlines).
# Empty = no auto-tag. Example: #mcp
MEMOS_AUTO_TAG=

# ── Remote HTTP mode (only when started with --http) ─────────────────────────
# Port to listen on (bound to 127.0.0.1). 0 / unset = random free port.
PORT=8765
# REQUIRED in --http mode. Shared secret for the static-token path; the server
# refuses to start without it. Sent by clients as `Authorization: Bearer <token>`,
# `X-API-Key: <token>`, or `?key=<token>`. Generate e.g. `openssl rand -hex 32`.
MCP_AUTH_TOKEN=

# ── OAuth 2.1 (optional; needed for hosted connectors like claude.ai) ─────────
# Public origin the server is reached at (no trailing /mcp). The OAuth
# resource/audience becomes ${MCP_PUBLIC_URL}/mcp. Required if OAUTH_ISSUER is set.
MCP_PUBLIC_URL=https://mcp.example.com
# Authorization-server issuer base URL. Setting it enables the OAuth Bearer-JWT
# path (JWKS is discovered from the issuer's metadata). Leave empty to disable.
# The issuer must support Dynamic Client Registration (RFC 7591) for self-
# registering clients, and must allow ${MCP_PUBLIC_URL}/mcp as a token audience.
OAUTH_ISSUER=
# Optional, comma-separated. Scopes to advertise in the protected-resource
# metadata. Default: none (advertise no custom scopes).
OAUTH_SCOPES=

# ── Identity allowlist (optional but recommended for OAuth) ───────────────────
# A valid token only proves the caller signed in to the IdP — with open sign-up
# that can be anyone. Restrict to specific identities; non-matching tokens get
# 403. While both are empty, any valid token is accepted and its sub/email is
# logged ("learn mode") so you can discover the value to pin here.
OAUTH_ALLOWED_SUBS=
OAUTH_ALLOWED_EMAILS=
